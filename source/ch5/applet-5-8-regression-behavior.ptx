<?xml version="1.0" encoding="UTF-8"?>
<section xml:id="applet-5-8-regression">
  <title>Applet Exploration: Behavior of Regression Lines</title>

  <exercises xml:id="exercises5-8-applet" hidden-label="yes">
    <title>Exploration Tasks</title>

    <p>Use the Analyzing Two Quantitative Variables applet with height and foot-length data.</p>

    <exercise xml:id="applet5-8-a" label="A5.8.a"><title>Baseline Regression Fit</title><statement><p>(a) Display regression line and judge whether it summarizes the linear relationship reasonably.</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-b" label="A5.8.b"><title>Predict Effect of High-Leverage Point</title><statement><p>(b) Predict effect of adding point (35, 60) on regression equation.</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-c" label="A5.8.c"><title>Add Point and Report New Equation</title><statement><p>(c) Add the point and report new equation.</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-d" label="A5.8.d"><title>Move New Point Vertically</title><statement><p>(d) Move the added point vertically and assess how strongly slope/intercept change.</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-e" label="A5.8.e"><title>Predict Effect of Central Point Movement</title><statement><p>(e) Revert and predict effect of moving point (29, 65) vertically.</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-f" label="A5.8.f"><title>Move Central Point</title><statement><p>(f) Move (29, 65) and compare influence to part (d).</p></statement><response/></exercise>
    <exercise xml:id="applet5-8-g" label="A5.8.g"><title>Influence Comparison</title><statement><p>(g) Which point is more influential and why under least squares?</p></statement><response/></exercise>
  </exercises>
</section>
