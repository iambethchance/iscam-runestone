            <cell>181</cell>
            <cell>183</cell>
          </row>
          <row>
            <cell halign="left">3</cell>
            <cell>353</cell>
            <cell>371</cell>
            <cell>342</cell>
          </row>
          <row>
            <cell halign="left">2</cell>
            <cell>235</cell>
