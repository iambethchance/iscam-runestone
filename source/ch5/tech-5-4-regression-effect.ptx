<?xml version="1.0" encoding="UTF-8"?>
<section xml:id="tech-5-4-regression-effect">
  <title>Technology Exploration: The Regression Effect</title>

  <exercises xml:id="exercises5-4-tech" hidden-label="yes">
    <title>The Study</title>

    <p>Using <c>Masters18.txt</c>, examine first-round vs second-round golf scores to study regression to the mean.</p>

    <exercise xml:id="tech5-4-a" label="T5.4.a"><title>Scatterplot and Correlation</title><statement><p>(a) Plot round 2 vs round 1 and describe association direction and strength.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-b" label="T5.4.b"><title>Sort and List Extremes</title><statement><p>(b) Sort by round-1 score and list top ten and bottom ten with round-2 scores.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-c" label="T5.4.c"><title>Improvement Counts</title><statement><p>(c) Count improvements in each group.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-d" label="T5.4.d"><title>Compare Improvement Rates</title><statement><p>(d) Which group improved more and by how much?</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-e" label="T5.4.e"><title>Median Round-2 Scores</title><statement><p>(e) Compare median round-2 scores for top-ten and bottom-ten first-round groups.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-f" label="T5.4.f"><title>y=x Line Interpretation</title><statement><p>(f) Add <m>y=x</m> line and identify examples of improvements and declines.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-g" label="T5.4.g"><title>Compare Candidate Lines</title><statement><p>(g) Evaluate whether <m>y=x</m> is a good summary and predict regression slope relative to 1.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-h" label="T5.4.h"><title>Mean Line Comparison</title><statement><p>(h) Add <m>\bar{y}</m> line and compare with expected regression line.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-i" label="T5.4.i"><title>Add Regression Line</title><statement><p>(i) Add regression line and describe location relative to previous lines.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-j" label="T5.4.j"><title>Regression Equation and Slope</title><statement><p>(j) Report equation and explain why slope tends to be less than 1 when SDs are similar.</p></statement><response/></exercise>
    <exercise xml:id="tech5-4-k" label="T5.4.k"><title>Regression to Mean Interpretation</title><statement><p>(k) Explain why slope less than 1 implies very good first rounds tend to worsen and poor first rounds tend to improve.</p></statement><response/></exercise>
  </exercises>
</section>
