        <row header="yes">
          <cell></cell>
          <cell>Judge 1</cell>
          <cell>Judge 2</cell>
          <cell>Judge 3</cell>
          <cell>Judge 4</cell>
          <cell>Judge 5</cell>
          <cell>Judge 6</cell>
          <cell>Judge 7</cell>
          <cell>Total</cell>
        </row>
        <row>
          <cell halign="left">Women on jury list</cell>
