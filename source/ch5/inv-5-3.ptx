    <exercise xml:id="practice-5-3-1" label="P5.3.1">
      <title>Chi-squared Test of Association</title>
      <statement>
        <p>Conduct a chi-squared test of association and report hypotheses, conditions, statistic, p-value, and conclusion.</p>
      </statement>
      <response/>
    </exercise>

    <exercise xml:id="practice-5-3-2" label="P5.3.2">
      <title>Largest Cell Contributions</title>
      <statement>
        <p>Which two or three cells contribute most to <m>\chi^2</m>? Are observed counts above or below expected in those cells, and what does that reveal?</p>
      </statement>
