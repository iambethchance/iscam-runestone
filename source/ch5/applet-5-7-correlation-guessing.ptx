<?xml version="1.0" encoding="UTF-8"?>
<section xml:id="applet-5-7-correlation">
  <title>Applet Exploration: Correlation Guessing Game</title>

  <p>Open the Guess the Correlation applet and repeatedly estimate the correlation from displayed scatterplots.</p>

  <exercises xml:id="exercises5-7-applet" hidden-label="yes">
    <title>Exploration Tasks</title>

    <exercise xml:id="applet5-7-a" label="A5.7.a"><title>First Guess</title><statement><p>(a) Enter your guess, check against actual value, and reflect on accuracy.</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-b" label="A5.7.b"><title>Second Guess</title><statement><p>(b) Repeat with a new sample and describe adjustments in your guessing strategy.</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-c" label="A5.7.c"><title>Ten Trials</title><statement><p>(c) Repeat for 10 scatterplots. Did your guessing improve?</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-d" label="A5.7.d"><title>Guess vs Actual</title><statement><p>(d) Use Track Performance: interpret Guess vs Actual plot and discuss whether high correlation implies good guessing.</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-e" label="A5.7.e"><title>Error vs Actual</title><statement><p>(e) Interpret Error vs Actual graph. Were some correlation values easier to guess?</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-f" label="A5.7.f"><title>Error vs Trial</title><statement><p>(f) Interpret Error vs Trial graph. Did ability improve over time?</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-g" label="A5.7.g"><title>Perfect Guesser Thought Experiment</title><statement><p>(g) If all guesses are exactly correct, what is correlation between guesses and actual values?</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-h" label="A5.7.h"><title>Systematic Offset Thought Experiment</title><statement><p>(h) If each guess is 0.2 too high, what is correlation between guesses and actual values?</p></statement><response/></exercise>
    <exercise xml:id="applet5-7-i" label="A5.7.i"><title>Interpretation Caveat</title><statement><p>(i) Does correlation equal to 1 between guesses and actuals guarantee accurate guesses? Explain.</p></statement><response/></exercise>
  </exercises>
</section>
